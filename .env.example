# ═══════════════════════════════════════
# EarningsPulse — Environment Variables
# ═══════════════════════════════════════
# Copy this file to .env and fill in your API keys.
# All keys are optional — the system will fall back to free endpoints.

# Alpha Vantage (free tier, 25 calls/day)
# Get your key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_key_here

# SEC API (sec-api.io free tier, 100 requests)
# Get your key at: https://sec-api.io/
SEC_API_KEY=your_key_here

# FRED API Key (optional — basic requests work without a key)
# Get your key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_key_here
